rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Validate issue uploads
    match /issues/{userId}_{timestamp}_{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('image/.*|video/.*|audio/.*');
    }
    
    // Validate comment verification proof uploads
    match /comments/{issueId}_{userId}_{timestamp}_{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
